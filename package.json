{
  "name": "fabric-store",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build-only": "vite build",
    "build": "run-p type-check lint:check stylelint:check format:check format:assets:check build-only",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "stylelint": "stylelint \"src/**/*.{vue,scss}\" --fix",
    "stylelint:check": "stylelint \"src/**/*.{vue,scss}\"",
    "format": "oxfmt \"src/**/*.{ts,js}\" --write --ignore-path .oxfmtignore",
    "format:check": "oxfmt \"src/**/*.{ts,js}\" --check --ignore-path .oxfmtignore",
    "format:assets": "prettier \"**/*.{json,md,yml,yaml}\" --write",
    "format:assets:check": "prettier \"**/*.{json,md,yml,yaml}\" --check",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "~1.60.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
